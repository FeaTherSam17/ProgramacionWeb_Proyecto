# Copy this file to `.env` for local development. DO NOT commit secrets to VCS.

# Database (production should use a managed Postgres/Supabase URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_DB_URL=
DB_SSL=auto

# Session / Auth
# Use a long random value for AUTH_SECRET and SESSION_SECRET in production.
SESSION_SECRET=your-session-secret
AUTH_SECRET=your-auth-secret
AUTH_ALLOWED_EMAILS=you@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Production callback (must match Google Console exactly)
GOOGLE_CALLBACK_URL=https://programacion-web-proyecto-lilac.vercel.app/api/auth/google/callback

# Site URLs
NUXT_PUBLIC_SITE_URL=https://programacion-web-proyecto-lilac.vercel.app/
NUXT_SITE_URL=https://programacion-web-proyecto-lilac.vercel.app/

# Optional third-party keys
SUPABASE_ANON_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Mail
SMTP_URL=
CONTACT_RECIPIENT_EMAIL=
CONTACT_SENDER_EMAIL=
